{erl_opts, [
  debug_info,
  warnings_as_errors,
  warn_export_all,
  {parse_transform, etran},
  {feature,maybe_expr,enable}
]}.

{deps, [
  {etran,      "0.5.0"},
  {util,       "1.3.2"},
  %% Both telemetry and prometheus are strictly optional: arterial only
  %% emits events through the generic arterial_observability facade (see
  %% its moduledoc), which dispatches to one of the backend modules below
  %% based on the `arterial` application's `observability` env var
  %% (default `telemetry`). Neither is in arterial.app.src's
  %% `applications` list -- only the configured backend's dependency is
  %% ever lazily started, the same pattern arterial_socket uses for `ssl`.
  {telemetry,  "1.3.0"},  % arterial_observability_telemetry backend
  {prometheus, "6.1.2"}   % arterial_observability_prometheus backend
]}.

{xref_checks, [undefined_function_calls, undefined_functions,
               deprecated_function_calls, deprecated_functions]}.

%% prometheus 6.1.2 (and its own dependency ddskerl) hardcode
%% warnings_as_errors in their own rebar.config and use bare `catch Expr`
%% syntax that newer OTP releases (29+) flag as a deprecation warning --
%% turning that warning into a build failure for a dependency we don't
%% control the source of. Override just drops warnings_as_errors for
%% these two deps when built as dependencies of arterial; doesn't touch
%% their source or any other erl_opts.
{overrides, [
  {override, prometheus, [{erl_opts, [debug_info]}]},
  {override, ddskerl,    [{erl_opts, [debug_info]}]}
]}.

%% `ssl` is not in arterial.app.src's `applications` list (it's started
%% lazily by arterial_socket only when a connection actually uses the
%% `ssl` transport, see that module -- not a hard runtime dependency for
%% tcp/udp-only users), but dialyzer still needs its PLT entries to check
%% calls into ssl:connect/3, ssl:close/1, etc.
{dialyzer, [{plt_extra_apps, [ssl, public_key]}]}.

{cover_enabled,  true}.
{cover_opts,     [verbose]}.
{cover_export_enabled, true}.

{pre_hooks,  [{compile, "make -s nif"}]}.
{post_hooks, [
  {clean,   "rm -f *.dump *.crashdump"}
]}.

{plugins,    [rebar3_hex, {rebar3_ex_doc, "0.3.0"}]}.
{hex,        [{doc, ex_doc}]}.

{ex_doc,     [
  {extras,   [
    {"README.md", #{title => "Overview"}},
    {"LICENSE",   #{title => "License"}}
  ]},
  {main,       "README.md"},
  {source_url, "https://github.com/saleyn/arterial"},
  {assets,     #{"assets" => "assets"}}
]}.

{profiles, [
  {test, [
    {extra_src_dirs, ["test"]},
    {erl_opts, [{d, 'TEST'}]},
    %% Only needed by test/shackle_bench.erl, to benchmark arterial
    %% against https://github.com/lpgauth/shackle head-to-head -- not a
    %% runtime dependency of the library itself.
    {deps, [{shackle, "0.7.3"}]}
  ]}
]}.